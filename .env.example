# Database
DATABASE_URL="postgresql://user:password@localhost:5432/flight_booking?schema=public"

# Next.js
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Environment
NODE_ENV=development

# JWT Secret (generate a secure random string)
JWT_SECRET=your-super-secret-jwt-key-change-this

# Payment Gateway (example - Stripe)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Email Service (example - SendGrid)
SENDGRID_API_KEY=your_sendgrid_api_key

# Airline/GDS API (placeholder)
AIRLINE_API_KEY=your_airline_api_key
AIRLINE_API_URL=https://api.airline-provider.com
